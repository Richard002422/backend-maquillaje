# Copiar a backend/api/.env y backend/ai-service/.env según corresponda.
# En Docker, los valores se inyectan vía docker-compose.

# --- API Node (Express) ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://glowlab:glowlab@localhost:5432/glowlab?schema=public

# Mínimo 32 caracteres (openssl rand -hex 32)
JWT_ACCESS_SECRET=cambiar_por_secreto_largo_de_al_menos_32_caracteres_xx

ACCESS_TOKEN_TTL_SEC=900

AI_SERVICE_URL=http://127.0.0.1:8000
INTERNAL_AI_TOKEN=compartido_api_ai_min_16_chars
AI_HTTP_TIMEOUT_MS=2500
AI_HTTP_RETRIES=1
AI_HTTP_RETRY_BASE_MS=200
API_JSON_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=180
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_HEAVY_MAX=20

# Orígenes CORS separados por coma (vacío = refleja cualquier origen en dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# --- Servicio IA (FastAPI) ---
INTERNAL_AI_TOKEN=compartido_api_ai_min_16_chars
